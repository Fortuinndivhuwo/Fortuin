#Create functions to add,minus,multiply and divide
#Adding function
def add(num1, num2):
   answer = num1 + num2
   return answer
def minus(num1, num2):
   answer = num1 - num2
   return answer
def multiply(num1, num2):
   answer = num1 * num2
   return answer  
def divide(num1, num2):
   answer = num1 / num2
   return answer
   
